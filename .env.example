# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_USER_ID=your_user_id

# Google Calendar Sync (server-side only — never VITE_ prefix)
# Step 1: Create OAuth2 Desktop credentials at https://console.cloud.google.com/apis/credentials
# Step 2: Enable Google Calendar API at https://console.cloud.google.com/apis/library
# Step 3: Run `node scripts/get-google-token.js` to obtain GOOGLE_REFRESH_TOKEN
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token
